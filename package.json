{
	"name": "comike-web-catalog-helper",
	"version": "1.0.0",
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "nest build",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint src",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"lint:fix": "eslint src --fix",
		"prettier": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"bootstrap": "sapphire-bootstrap"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sapphire-sh/comike-web-catalog-helper.git"
	},
	"author": "sapphire",
	"type": "module",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/sapphire-sh/comike-web-catalog-helper/issues"
	},
	"homepage": "https://github.com/sapphire-sh/comike-web-catalog-helper#readme",
	"dependencies": {
		"@nestjs/common": "^9.0.4",
		"@nestjs/core": "^9.0.4",
		"@nestjs/platform-express": "^9.0.4",
		"csv-parse": "^5.3.0",
		"reflect-metadata": "^0.1.13",
		"rxjs": "^7.5.6",
		"@sapphire-sh/utils": "^1.61.0"
	},
	"devDependencies": {
		"@nestjs/cli": "^9.0.0",
		"@nestjs/schematics": "^9.0.1",
		"@types/express": "^4.17.13",
		"@types/node": "^18.0.6",
		"@types/supertest": "^2.0.12",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.5.3",
		"rimraf": "^3.0.2",
		"source-map-support": "^0.5.21",
		"ts-loader": "^9.3.1",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.0.0",
		"typescript": "^5.9.3",
		"eslint-plugin-promise": "^7.2.1",
		"prettier-plugin-organize-imports": "^4.1.0",
		"typescript-eslint": "^8.58.0"
	}
}
